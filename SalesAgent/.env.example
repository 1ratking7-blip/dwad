# Copy to .env and fill in before using `npm run send -- --confirm`.
# .env is gitignored — never commit real credentials.

# Any standard SMTP account works: Gmail (use an App Password, not your login password —
# generate one at https://myaccount.google.com/apppasswords, requires 2-Step Verification),
# a transactional provider's SMTP endpoint (SendGrid, Mailgun, Postmark, etc.), or your
# own mailbox.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=1ratking7@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional — defaults to "<SENDER_CONFIG.sender_name> <SMTP_USER>" if unset.
SMTP_FROM=
